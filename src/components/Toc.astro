---
interface Props {
  items: Array<{
    id: string;
    text: string;
  }>;
}

const { items } = Astro.props;
---

<nav class="toc-desktop" id="toc-desktop" aria-label="Table of Contents">
  <div class="toc-title">Contents</div>
  <ul class="toc-list">
    {items.map((item) => (
      <li><a href={`#${item.id}`} class="toc-link">{item.text}</a></li>
    ))}
  </ul>
</nav>
<div class="toc-overlay" id="toc-overlay">
  <div class="toc-overlay-content">
    <div class="toc-overlay-header">
      <span>Table of Contents</span>
      <button class="toc-overlay-close" id="toc-overlay-close">&times;</button>
    </div>
    <ul class="toc-overlay-list">
      {items.map((item) => (
        <li><a href={`#${item.id}`} class="toc-overlay-link">{item.text}</a></li>
      ))}
    </ul>
  </div>
</div>
