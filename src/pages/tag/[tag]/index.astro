---
import type { GetStaticPaths } from 'astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SectionTitle } from '../../../ui/SectionTitle';
import { WritingListItem } from '../../../ui/WritingListItem';
import {
  formatTagLabel,
  getPostPermalink,
  getPostsByTagSlug,
  getTagSummaries,
} from '../../../lib/content';
import { formatDisplayDate } from '../../../lib/site';

export const getStaticPaths = (async () => {
  const tags = await getTagSummaries();

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
const posts = (await getPostsByTagSlug(tag.slug)).map((post) => ({
  id: post.id,
  title: post.data.title,
  href: getPostPermalink(post),
  date: formatDisplayDate(post.data.date),
  tags: post.data.tags.map(formatTagLabel),
}));
---

<BaseLayout
  title={`Tag: ${tag.name}`}
  canonicalPath={`/tag/${tag.slug}/`}
  pageClass="page-shell--content"
>
  <section class="posts-listing-section latest-writing-section">
    <SectionTitle
      icon="writing"
      title={`Posts tagged ${formatTagLabel(tag.name)}`}
      headingLevel={1}
      actionHref="/tag/"
      actionLabel="View all tags"
    />
    <div class="latest-writing-section__list">
      {posts.map((post) => (
        <WritingListItem
          key={post.id}
          date={post.date}
          href={post.href}
          tags={post.tags}
          title={post.title}
        />
      ))}
    </div>
  </section>
</BaseLayout>
